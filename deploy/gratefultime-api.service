[Unit]
Description=GratefulTime v2 API
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/gratefultime-v2-backend
EnvironmentFile=%h/gratefultime-v2-backend/.env
Environment=PORT=33540
ExecStart=%h/gratefultime-v2-backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 33540 --workers 1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
